def test_mfa_logging_redacts_query_and_number(caplog):
  handler = AzureMFA(url="https://login.ug.kth.se")
  response = MockResponse(
    MFA_HTML,
    url="https://login.ug.kth.se/auth?ctx=secret"
  )

  with caplog.at_level(logging.DEBUG, logger="weblogin.microsoft"):
    assert handler.need_login(response)

  assert "ctx=secret" not in caplog.text
  assert "42" not in caplog.text
  assert "https://login.ug.kth.se/auth?..." in caplog.text
